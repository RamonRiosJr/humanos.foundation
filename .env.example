# Humanos Foundation - Environment Configuration
# Copy this file to .env and fill in the values below.

# ------------------------------------------------------------------------------
# Growth & Analytics (Phase 2 Roadmap)
# ------------------------------------------------------------------------------
# PostHog API Key for tracking waitlist conversions, scroll depth, and active users
# Get this from your PostHog project settings. Leave blank in dev to disable tracking.
VITE_POSTHOG_KEY=your_posthog_project_api_key

# Optional: Set this if you are self-hosting PostHog or using the EU region
# Default is the US cloud (https://us.i.posthog.com)
VITE_POSTHOG_HOST=https://us.i.posthog.com


# ------------------------------------------------------------------------------
# Future Backend Integration (Odoo ERP)
# ------------------------------------------------------------------------------
# The URL for the Headless Odoo Backend (team.humanos.foundation)
# VITE_ODOO_API_URL=https://team.humanos.foundation/api/v1
