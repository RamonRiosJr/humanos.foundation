        },
        "email": {
            "type": "string"
        },
        "role": {
            "type": "string",
            "enum": [
                "patient",
                "clinician",
                "technologist",
                "researcher",
                "advocate",
                "journalist",
                "other"
            ]
        },
        "reason": {
            "type": "string"
        },
        "newsletter": {
            "type": "boolean",
            "default": true
        },
        "volunteer": {
